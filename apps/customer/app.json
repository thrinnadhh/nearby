{
  "expo": {
    "name": "NearBy",
    "slug": "nearby-customer",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "nearby-customer",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#2563EB"
    },
    "ios": {
      "bundleIdentifier": "app.nearby.customer",
      "supportsTablet": false
    },
    "android": {
      "package": "app.nearby.customer",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#2563EB"
      }
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
