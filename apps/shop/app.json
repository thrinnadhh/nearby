{
  "expo": {
    "name": "NearBy Shop Owner",
    "slug": "nearby-shop",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "ios": {
      "supportsTabletMode": true,
      "bundleIdentifier": "com.nearby.shop"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.nearby.shop",
      "versionCode": 1
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#000000"
        }
      ]
    ],
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "nearby-shop"
      }
    },
    "scheme": "nearby-shop",
    "owner": "nearby-app"
  }
}
