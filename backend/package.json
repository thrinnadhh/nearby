{
  "name": "nearby-backend",
  "version": "1.0.0",
  "description": "NearBy hyperlocal commerce platform — API server",
  "type": "module",
  "scripts": {
    "dev": "nodemon src/index.js",
    "start": "node src/index.js",
    "seed:typesense": "node src/scripts/seedTypesense.js",
    "test": "jest --coverage",
    "test:sprint1": "npx jest --runInBand --coverage=false src/__tests__/integration/sprint1.e2e.test.js",
    "test:sprint2": "npx jest --runInBand --coverage=false src/__tests__/integration/shops.test.js src/__tests__/integration/shopsKyc.test.js src/__tests__/integration/products.test.js src/__tests__/integration/search.test.js src/__tests__/unit/productImagePipeline.test.js src/__tests__/unit/typesenseSchema.test.js",
    "test:e2e:sprint1-2": "npx jest --runInBand --coverage=false src/__tests__/integration/sprint1.e2e.test.js src/__tests__/integration/auth.test.js src/__tests__/integration/server.test.js src/__tests__/integration/shops.test.js src/__tests__/integration/shopsKyc.test.js src/__tests__/integration/products.test.js src/__tests__/integration/search.test.js src/__tests__/unit/productImagePipeline.test.js src/__tests__/unit/typesenseSchema.test.js",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.88.0",
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/s3-request-presigner": "^3.1029.0",
    "@supabase/supabase-js": "^2.43.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.7.0",
    "cors": "^2.8.5",
    "csv-parse": "^5.6.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "joi": "^17.13.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "rate-limit-redis": "^4.3.1",
    "sharp": "^0.33.4",
    "socket.io": "^4.7.5",
    "typesense": "^1.8.2",
    "uuid": "^10.0.0",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "babel-jest": "^29.7.0",
    "eslint": "^9.5.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.3",
    "socket.io-client": "^4.8.3",
    "supertest": "^7.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
