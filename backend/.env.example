# NearBy Backend Environment Variables
# Copy to .env and fill in your values. Never commit .env to git.

# ─── SERVER ────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── AUTHENTICATION ───────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_key_change_in_production
JWT_EXPIRES_IN=7d

# ─── DATABASE & SERVICES ──────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_ANON_KEY=your_anon_key

REDIS_URL=redis://localhost:6379

# ─── SEARCH ENGINE ─────────────────────────────────────────────────────────
TYPESENSE_API_KEY=your_typesense_api_key
TYPESENSE_HOST=localhost
TYPESENSE_PORT=8108
TYPESENSE_PROTOCOL=http

# ─── FILE STORAGE ──────────────────────────────────────────────────────────
CLOUDFLARE_R2_ACCESS_KEY_ID=your_r2_access_key
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your_r2_secret_key
CLOUDFLARE_R2_ENDPOINT=https://your-account.r2.cloudflarestorage.com
CLOUDFLARE_ACCOUNT_ID=your_account_id
CLOUDFLARE_R2_PRODUCT_BUCKET=nearby-products
CLOUDFLARE_R2_KYC_BUCKET=nearby-kyc

# ─── PAYMENT GATEWAY ──────────────────────────────────────────────────────
CASHFREE_APP_ID=your_cashfree_app_id
CASHFREE_APP_SECRET=your_cashfree_app_secret
CASHFREE_WEBHOOK_SECRET=your_cashfree_webhook_secret

# ─── SMS & OTP ─────────────────────────────────────────────────────────────
MSG91_AUTH_KEY=your_msg91_auth_key

# ─── PUSH NOTIFICATIONS ───────────────────────────────────────────────────
FCM_SERVICE_ACCOUNT_JSON={...firebase_service_account_json...}

# ─── MAPS & GEOCODING ──────────────────────────────────────────────────────
OLA_MAPS_API_KEY=your_ola_maps_api_key

# ─── SOCKET.IO CORS ───────────────────────────────────────────────────────
# Comma-separated list of allowed origins for WebSocket connections
SOCKET_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002

# ─── MONITORING & LOGGING ────────────────────────────────────────────────
LOG_LEVEL=info
SENTRY_DSN=

# ─── FEATURE FLAGS ─────────────────────────────────────────────────────────
ENABLE_TRUSTS_SCORE_ENGINE=true
ENABLE_NOTIFICATIONS_QUEUE=true
